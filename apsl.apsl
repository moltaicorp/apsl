# ── Graphs: main pipelines ──
# All flow chains are linear: each node takes one input and produces one output.
# Multi-input scenarios use separate flow lines in the same graph.

graph apslc : Source -> Hash
  flow  in -> parse_str -> apslc_canon -> content_hash -> out

graph apslc_check_pipeline : Source -> String
  flow  in -> parse_str -> link -> type_check -> apslc_check -> out

graph apslc_string_strict_pipeline : Source -> String
  flow  in -> parse_str -> link -> type_check -> check_string_strict -> out

graph apslc_compile_artifact : Source -> CanonicalArtifact
  flow  in -> parse_str -> link -> artifact_check -> compile_artifact -> out

graph apsl_lint : Source -> CxReport
  flow  in -> parse_str -> type_check -> prove -> out

graph apsl_lint_pred : Source -> SmtReport
  flow  in -> parse_str -> type_check -> discharge_node -> out

graph apsl_lint_explain : Source -> String
  flow  in -> parse_str -> type_check -> prove -> out
  flow  in -> parse_str -> report_explain -> out

graph apsl_cert_key_new : String -> Key
  flow  in -> cert_cli_key_new -> out

graph apsl_cert_emit : Source -> Hash
  flow  in -> parse_str -> type_check -> prove
  flow  in -> parse_str -> type_check -> discharge_node
  flow  in -> cert_emit -> store_put -> out

graph apsl_cert_verify : Hash -> Bool
  flow  in -> store_get -> cert_cli_verify -> out

graph apsl_cert_show : Hash -> Cert
  flow  in -> store_get -> out

graph apsl_runtime_run : Source -> Record
  flow  in -> load_program -> runtime_run -> out

graph apsl_runtime_nodes : Source -> String
  flow  in -> load_program -> runtime_cli_nodes -> out

graph apsl_runtime_verify : Path -> Bool
  flow  in -> runtime_cli_verify -> out

graph apsl_workbench_compile : Source -> String
  flow  in -> pipeline_compile -> out

graph apsl_workbench_build : Source -> String
  flow  in -> pipeline_node_names -> nix_build
  flow  in -> pipeline_compile -> out

graph apsl_workbench_verify : Source -> Verdict
  flow  in -> handler_verify -> out

graph apsl_verify_numeric : String -> Verdict
  flow  in -> verify_numeric_node -> out
