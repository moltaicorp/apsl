# apsl.apsl — APSL's own pipeline, expressed in APSL.
#
# Every significant function across 14 crates is modeled as an APSL node.
# Graphs compose the main pipelines. Types alias complex Rust structures
# to String for the spec surface.

type Source = String
type AST = String
type Program = String
type TypedProgram = String
type CxReport = String
type SmtReport = String
type Cert = String
type Hash = String
type Path = String
type Token = String
type World = String
type Verdict = String
type Manifest = String
type Record = String
type Key = String
type Tcb = String
type VerificationObligation = String
type EvidenceState = String
type AcceptedEvidence <: EvidenceState = String
type Proven <: AcceptedEvidence = String
type Tested <: AcceptedEvidence = String
type Observed <: AcceptedEvidence = String
type NotApplicable <: AcceptedEvidence = String
type Unknown <: EvidenceState = String
type Failed <: EvidenceState = String
type VerificationPolicy = { required: VerificationObligation[], accepted: AcceptedEvidence[] }
type ContractCommitment = Hash
type ImplementationCommitment = Hash
type VerifierCommitment = Hash
type InputCommitment = Hash
type OutputCommitment = Hash
type EvidenceCommitment = Hash
type VerificationEvidence = { contract: ContractCommitment, implementation: ImplementationCommitment, verifier: VerifierCommitment, input: InputCommitment, output: OutputCommitment, artifact: EvidenceCommitment, state: EvidenceState }
type VerificationContract = { contract: ContractCommitment, policy: VerificationPolicy, obligations: VerificationObligation[] }
type NodeContract = String
type NodePlacement = String
type StateKind = String
type CheckSet = String
type CheckedProgram = String
type CanonicalArtifact = String

